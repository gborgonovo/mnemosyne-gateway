system:
  version: 1.0
  debug: true

# Graph Configuration (v0.3+ Hybrid File-First)
# The system now uses KùzuDB and ChromaDB automatically.
# No manual URI/User/Password required for the local-first storage.


attention:
  activation_threshold: 0.5  # Minimum heat to appear in briefing
  peak_threshold: 0.7        # Heat level that triggers NODE_ENERGIZED event
  propagation_dampening:
    forward: 1.0
    backward: 0.5

  # Decay rates per node type (applied per hour).
  # Half-life formula: ln(0.5) / ln(1 - rate)
  # Use scripts/simulate_decay.py to visualize curves before changing these.
  decay_rates:
    Node: 0.0025        # half-life ~11 days
    Goal: 0.00026       # half-life ~112 days (~4 months)
    Task: 0.00045       # half-life ~64 days (~2 months)
    Observation: 0.004  # half-life ~7 days

  # Activation boost per interaction type
  boost_weights:
    file_edit: 0.6      # File modified on disk
    mcp_query: 0.2      # Node retrieved via MCP or API
    proximity: 0.05     # Indirect boost to semantic neighbors of an interacted node

  # Dormant node detection and resurfacing
  dormant:
    resurface_boost: 0.05   # Boost applied each gardener cycle to dormant nodes
    ceiling: 0.25           # Max activation a dormant node can reach via resurfacing
    days_node: 27           # Days of inactivity before a Node is considered dormant
    days_goal_task: 30      # Days of inactivity before a Goal/Task is considered dormant
    min_interactions: 5     # Min past interactions required to be eligible for dormant detection

initiative:
  initiative_threshold: 0.5     # Min activation for a source node to trigger checks
  explanation_threshold: 0.4    # Max activation for a neighbor to be considered forgotten

llm:
  # The Butler: Higher level reasoning, extraction, and initiative.
  # MODES: 
  # - "mock": Fast dev mode (Static responses, no AI costs/latency)
  # - "ollama": Local inference (Privacy focus)
  # - "openai": Original OpenAI API
  # - "remote": Any OpenAI-compatible API (DeepSeek, vLLM, Azure, etc.)
  butler:
    mode: "mock"
    model_name: "gpt-4o-mini"           # Local model name for Ollama, or OpenAI model name
    base_url: ""                        # Required for "remote" or custom "ollama" ports
    api_key: ""                         # Variable name in .env (e.g. OPENAI_API_KEY)

  # Semantic Memory: High-performance vector generation for search.
  # MODES: same as butler (recommend "ollama" with nomic-embed-text for local use)
  embeddings:
    enabled: true                       # Master toggle for Layer 2 (Semantic Search)
    mode: "mock"
    model_name: "text-embedding-3-small"
    base_url: ""
    api_key: ""

  display_name: "The Butler (Mnemosyne)" # Name shown in Open WebUI / API Clients
  
  prompts:
    butler: |
      Sei The Butler, un'interfaccia di middleware cognitivo progettata per l'architettura e il recupero della conoscenza.
      Il tuo ruolo è agire come uno strato di consapevolezza analitica tra l'utente e il suo patrimonio informativo (Mnemosyne).
      Il tuo tono è preciso, oggettivo e orientato all'efficienza, mantenendo una professionalità distaccata ma collaborativa.
      RISPONDI SEMPRE IN ITALIANO.
      
      CRITICAL INSTRUCTION - MEMORY PRIORITY:
      Hai accesso al 'Connectome' (grafo della memoria) dell'utente tramite la sezione [MNEMOSYNE MEMORY RETRIEVAL].
      Quando questa sezione è presente, DEVI USARE ESCLUSIVAMENTE QUESTE INFORMAZIONI per rispondere.
      NON inventare, NON usare la tua conoscenza generale se il grafo contiene dati specifici sull'argomento.
      Se il grafo dice che "stalla" ha certe proprietà o collegamenti, USA QUELLI, non definizioni generiche.
      
      IMPORTANTE - IGIENE TECNICA:
      Il grafo riporta a volte metadati come "Obs_..." o "MENTIONED_IN". 
      IGNORA COMPLETAMENTE questi codici. Concentrati solo sul significato del testo e sulle connessioni tra i concetti reali (es. "B&B", "Silo"). 
      Non citare MAI codici come "Obs_12345" nella tua risposta.
      
      Se viene fornito un 'Proactive Context', esso contiene argomenti semanticamente correlati alla discussione attuale ma non menzionati di recente.

      INTEGRA questi argomenti proattivi in modo naturale nella tua risposta se aggiungono valore. Non forzarli.

    tester: |
      Sei il Mnemosyne Lab Tester, una variante analitica del Butler progettata esplicitamente per il collaudo del grafo di memoria.
      Il tuo obiettivo è duplice:
      1. Rispondere all'utente sfruttando le informazioni estratte dal database (sezione [MNEMOSYNE MEMORY RETRIEVAL]).
      2. Mantenere totale trasparenza tecnica riguardo al processo di recupero dei dati.
      
      REGOLE DI TRASPARENZA E RECUPERO:
      - DEVI USARE i dettagli presenti in 'Contesto correlato' o 'Connessioni' per descrivere un nodo, anche se il nodo principale non ha una descrizione propria.
      - Se un nodo (es: "Ganaghello") è vuoto ma i suoi vicini contengono informazioni su di esso, usa quelle informazioni per rispondere spiegando la connessione.
      - Menziona chiaramente quando le informazioni provengono dalla tua conoscenza generale e non dal grafo.
      - Evita di riportare al puro utente codici grezzi (come "Obs_"), ma illustra con precisione chirurgica le connessioni dedotte dal contesto.

gardener:
  interval_seconds: 3600    # Run every hour
  similarity_threshold: 0.85

gateway:
  host: "0.0.0.0"
  port: 4001

retrieval:
  # Numero di concetti correlati da includere nel contesto della chat per ogni entità rilevata
  neighbors_limit: 5            
  
  # Numero di concetti correlati da mostrare durante una ricerca esplicita (es. via MCP o API)
  search_neighbors_limit: 10     
  
  # Numero di messaggi/osservazioni passate dell'utente da recuperare per ogni concetto citato
  observation_limit: 3           
  
  # Numero massimo di caratteri per ogni osservazione recuperata (evita di saturare il contesto dell'LLM)
  observation_text_limit: 150    
  
  # Profondità massima per l'analisi d'impatto (quanti passaggi logici seguire nel grafo delle dipendenze)
  impact_depth: 3                
  
  # Numero massimo di riflessioni proattive o suggerimenti da mostrare contemporaneamente
  initiative_limit: 3            
  
  # Numero di voci da mostrare nella cronologia delle attività recenti
  history_limit: 10
