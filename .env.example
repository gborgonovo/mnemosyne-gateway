# .env example for Mnemosyne gateway
# Copy this file to .env and fill in the real values.

# LLM provider (OpenAI example)
OPENAI_API_KEY=your_openai_api_key_here

# Optional Ollama URL if using Ollama mode
OLLAMA_URL=http://127.0.0.1:11434

# Gateway URL (used by plugin_runner when running on a separate machine)
MNEMOSYNE_GATEWAY_URL=http://localhost:4001

# Optional API key for authenticated gateway endpoints
MNEMOSYNE_API_KEY=

# Alfred — outbound email account for plugin delivery
ALFRED_EMAIL=alfred@example.com
ALFRED_EMAIL_PASSWORD=your_password_here
ALFRED_SMTP_HOST=smtps.your-provider.com
ALFRED_SMTP_PORT=465
ALFRED_EMAIL_TO=you@example.com

# Alfred — ntfy push notifications (optional)
# NTFY_TOPIC=your-private-topic
# NTFY_URL=https://ntfy.sh
